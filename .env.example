# ── App ──────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
WEBHOOK_SECRET=your-ghl-webhook-secret

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── GHL — OPTIONAL ──────────────────────────────
# The current ingestion path is the inline-transcript webhook at
# /webhooks/ghl/transcript-ready, which carries the full transcript
# and UTM merge tags. No Contacts API call is made, so these can
# be left blank for new client deployments. Kept here for future
# re-introduction or if a feature reaches back into GHL data.
# GHL_API_KEY=
# GHL_LOCATION_ID=

# ── Anthropic ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack ────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SCORECARD_CHANNEL=sales-scorecards
SLACK_REPORTS_CHANNEL=sales-reports
SLACK_MARKETING_CHANNEL=sales-reports

# ── Business context (optional) ─────────────────
# Leave blank for generic sales analysis. Fill in for
# industry/offer-specific scoring and coaching.
# Example: "We are a digital marketing agency selling monthly retainer
# packages ($2500-$5000/mo) to local service businesses. Our main offer
# is lead generation via Meta and Google Ads. Sales cycle is typically
# 1-2 calls. Common competitors: GoHighLevel resellers, local agencies."
BUSINESS_CONTEXT=

# ── Celery beat schedule ─────────────────────────
WEEKLY_REPORT_DAY=monday
WEEKLY_REPORT_HOUR=8

# ── UI public URL prefix ─────────────────────────
# Required when this app is fronted by a path-stripping reverse proxy
# (Caddy `handle_path /salesgrader/* {...}` strips the prefix). Templates
# prepend this to every link so the browser hits the correct public URL.
# Leave blank for local dev / direct exposure. Set per-client in production:
#   /salesgrader   for gogrowlabs
#   /colt          for the Colt deployment
#   etc.
URL_PREFIX=

# ── Observability (optional) ─────────────────────
# Leave SENTRY_DSN blank to disable Sentry entirely (dev default).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
