# ── App ──────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
WEBHOOK_SECRET=your-ghl-webhook-secret

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── GHL ──────────────────────────────────────────
GHL_API_KEY=your-ghl-private-integration-key
GHL_LOCATION_ID=your-sub-account-location-id

# ── Anthropic ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack ────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SCORECARD_CHANNEL=sales-scorecards
SLACK_REPORTS_CHANNEL=sales-reports

# ── Celery beat schedule ─────────────────────────
WEEKLY_REPORT_DAY=monday
WEEKLY_REPORT_HOUR=8

# ── Observability (optional) ─────────────────────
# Leave SENTRY_DSN blank to disable Sentry entirely (dev default).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
