# Caddy reverse proxy environment.
# Copy to .env (in this same directory) and fill in real values.

# Apex domain you control. Caddy will serve api.<DOMAIN> publicly.
# Example: yourcompany.com  →  Caddy serves https://api.yourcompany.com
DOMAIN=yourcompany.com

# Email Let's Encrypt uses for cert expiry warnings and account recovery.
# Use a real address — losing access to it can complicate ACME challenges later.
ACME_EMAIL=ops@yourcompany.com
