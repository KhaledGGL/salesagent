# ─────────────────────────────────────────────────────────────────────────────
# Caddy reverse proxy — multi-tenant routing
#
# Two routing models are supported in this file. Pick whichever fits the
# client; you can mix freely on the same host.
#
#   1. Per-client hostname (RECOMMENDED for new clients)
#      Each client brings their own domain (e.g. `analyzer.acme.com`).
#      Caddy obtains a separate Let's Encrypt cert per host automatically.
#      No URL_PREFIX in the app's `.env`. Cleanest URLs.
#
#   2. Shared host with path prefix (legacy / shared infra)
#      All clients live under `api.<DOMAIN>/<slug>/*`. One cert covers
#      everything, but every client must set `URL_PREFIX=/<slug>` in
#      their app `.env` so internal links resolve.
#
# DNS:
#   Per-host model → A record for the client's chosen hostname → VPS IP
#   Shared model   → A record for `api.<DOMAIN>` → VPS IP
#
# To add a new tenant:
#   1. Stand it up in its own docker-compose project, joined to the
#      `web` external network (see infra/caddy/README.md)
#   2. Add a host block (per-host) OR a `handle_path` block (shared)
#   3. `docker compose -f /srv/caddy/docker-compose.yml exec caddy \
#         caddy reload --config /etc/caddy/Caddyfile --adapter caddyfile`
# ─────────────────────────────────────────────────────────────────────────────
{
	# Global options
	email {$ACME_EMAIL}

	# Uncomment to use the Let's Encrypt staging environment while
	# debugging DNS / cert issuance. Avoids burning the production rate limit.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ═══════════════════════════════════════════════════════════════════════════
# MODEL 1 — Per-client hostname (recommended)
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy the `EXAMPLE_CLIENT_HOSTNAME` block per tenant. Each block:
#   - matches a single hostname (no `api.{$DOMAIN}` wrapper)
#   - applies security headers
#   - basicauth-gates the `/ui` dashboard (3 leadership users share creds)
#   - leaves webhooks + health endpoints unauthenticated (URL is the secret)
#
# Generate the basicauth hash with:
#   docker compose exec caddy caddy hash-password
#
# In each client's app `.env`, leave `URL_PREFIX=` blank so the app serves
# from `/`. The webhook URL becomes:
#   https://<client-hostname>/webhooks/ghl/transcript-ready
# The dashboard becomes:
#   https://<client-hostname>/ui/

# ─── Acme Inc. — slug=acme — example, uncomment + adapt ─────────────────────
# analyzer.acme.com {
#     header {
#         Strict-Transport-Security "max-age=31536000; includeSubDomains"
#         X-Content-Type-Options "nosniff"
#         X-Frame-Options "DENY"
#         Referrer-Policy "strict-origin-when-cross-origin"
#         -Server
#     }
#
#     @ui path /ui /ui/*
#     handle @ui {
#         basicauth {
#             acme $2a$14$REPLACE_WITH_CADDY_HASH_PASSWORD_OUTPUT
#         }
#         reverse_proxy acme_api:8000 {
#             header_up X-Real-IP {remote_host}
#         }
#     }
#
#     reverse_proxy acme_api:8000 {
#         header_up X-Real-IP {remote_host}
#     }
# }

# ═══════════════════════════════════════════════════════════════════════════
# MODEL 2 — Shared host with path prefix (legacy / first-tenant infra)
# ═══════════════════════════════════════════════════════════════════════════
#
# Kept for the existing `salesgrader` deployment under
# `api.<DOMAIN>/salesgrader/*`. New clients should use Model 1 above.

api.{$DOMAIN} {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# ── Sales Call Analyzer ──────────────────────────────────────────────
	# Webhook URL: https://api.<DOMAIN>/salesgrader/webhooks/ghl/transcript-ready
	# Health:      https://api.<DOMAIN>/salesgrader/health/ready
	handle_path /salesgrader/* {
		reverse_proxy sales_api:8000 {
			header_up X-Real-IP {remote_host}
		}
	}

	# ── Default response at the root path ────────────────────────────────
	handle {
		respond "Caddy reverse proxy OK. Use /<agent>/<path> to reach a service." 200
	}
}
